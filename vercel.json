{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/flujo-operacional", "destination": "/flujo-operacional.html" },
    { "source": "/crm", "destination": "/crm-dist/index.html" },
    { "source": "/crm/:path*", "destination": "/crm-dist/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/evaluador",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
