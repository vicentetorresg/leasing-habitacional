{
  "crons": [
    {
      "path": "/api/vivienda-mailing",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/mailing-aprobados",
      "schedule": "0 14 * * 1,5"
    }
  ],
  "cleanUrls": true,
  "rewrites": [
    { "source": "/flujo-operacional", "destination": "/flujo-operacional.html" },
    { "source": "/casa-pronta", "destination": "/casa-pronta.html" },
    { "source": "/propiedades", "destination": "/assetplan" },
    { "source": "/leasing-funnel", "destination": "/leasing-funnel.html" },
    { "source": "/leasing-dm-tiktok", "destination": "/leasing-dm-tiktok.html" },
    { "source": "/leasing-dm-meta", "destination": "/leasing-dm-meta.html" },
    { "source": "/leasing-tiktok-ads", "destination": "/leasing-tiktok-ads.html" },
    { "source": "/viviendas-form", "destination": "/viviendas-form.html" },
    { "source": "/viviendas-form-dos", "destination": "/viviendas-form-dos.html" },
    { "source": "/viviendas-form-55", "destination": "/viviendas-form-55.html" },
    { "source": "/viviendas-form-dos-55", "destination": "/viviendas-form-dos-55.html" },
    { "source": "/subir-fotos", "destination": "/subir-fotos.html" },
    { "source": "/galeria", "destination": "/api/galeria" },
    { "source": "/marketplace", "destination": "/marketplace.html" },
    { "source": "/crm", "destination": "/crm-dist/index" },
    { "source": "/crm/:path*", "destination": "/crm-dist/index" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/evaluador",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/crm-dist/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
